{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Key": "SuperSecretDevelopmentKeyForTestingOnly123!",
    "Issuer": "CompanyApp",
    "Audience": "CompanyAppUsers"
  },
  "ReverseProxy": {
    "Routes": {
      "userMgmtRoute": {
        "ClusterId": "userMgmtCluster",
        "Match": {
          "Path": "/user-mgmt"
        },
        "Transforms": [
          { "PathSet": "/users" }
        ]
      },
      "prodMgmtRoute": {
        "ClusterId": "prodMgmtCluster",
        "Match": {
          "Path": "/prod-mgmt"
        },
        "Transforms": [
          { "PathSet": "/products" }
        ]
      },
    },
    "Clusters": {
      "userMgmtCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8081"
          }
        }
      },
      "prodMgmtCluster": {
        "Destinations": {
          "destination1": {
            "Address": "http://localhost:8082"
          }
        }
      }
    }
  }
}
